# Cloudflare Pages redirects. Evaluated at the edge.

# Return a real HTTP 404 for design-system paths. The files are deleted
# from the build output (see `build` script in package.json), so Pages
# falls through to this rule and returns 404 status instead of the default
# 200-for-any-html behavior.
/design-system/* /404 404
/design-system /404 404

# Note: www -> apex is handled at zone level via Cloudflare Redirect Rules
# (Rules > Redirect Rules), not here.
